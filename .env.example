SECRET_KEY=change-me-before-production
DEBUG=0
ALLOWED_HOSTS=localhost,127.0.0.1

# Optional. If omitted, Django uses local SQLite.
# Example:
# DATABASE_URL=postgres://diplom:diplom_password@db:5432/diplom
DATABASE_URL=

CSRF_TRUSTED_ORIGINS=

# Security flags for public HTTPS deployment.
SECURE_SSL_REDIRECT=0
SESSION_COOKIE_SECURE=0
CSRF_COOKIE_SECURE=0
CSRF_COOKIE_HTTPONLY=0
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=0
SECURE_HSTS_PRELOAD=0
DATA_UPLOAD_MAX_MEMORY_SIZE=2621440

# Public maintenance mode. The file is created by:
# python manage.py maintenance on/off/status
MAINTENANCE_MODE_FILE=
MAINTENANCE_EXEMPT_PATHS=/healthz/,/static/,/favicon.ico
MAINTENANCE_RETRY_AFTER=900

# Public OMSU dashboard API.
# In production set OMSU_API_REQUIRE_KEY=1 and put one or more comma-separated keys.
OMSU_API_SNAPSHOT_REFRESH_SECONDS=300
OMSU_API_COMMENT_REFRESH_SECONDS=2
OMSU_API_REQUIRE_KEY=0
OMSU_API_KEYS=

# Docker Compose defaults. Change before public deployment.
POSTGRES_DB=diplom
POSTGRES_USER=diplom
POSTGRES_PASSWORD=change-me
